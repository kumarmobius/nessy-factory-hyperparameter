{
  "model_name": "denoise_ae",

  "encoder_layers_units": "128,128,64",
  "decoder_layers_units": "64,128,128",
  "latent_dim": 32,
  "weight_init": "xavier_uniform",

  "encoder_activation": "relu",
  "decoder_activation": "relu",

  "encoder_batch_norm": true,
  "decoder_batch_norm": true,

  "encoder_dropout": 0.2,
  "decoder_dropout": 0.2,

  "learning_rate": 0.001,
  
  "optimizer": "adam",
  "batch_size": 128,
  "epochs": 20,

  "weight_decay": 0.00001,
  "noise_factor": 0.1,
  "noise_type": "gaussian"
}